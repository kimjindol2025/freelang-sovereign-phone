fn test_E1_k8s_deployment_time() -> TestResult {
    // R5: K8s deployment < 30s
    let engine = create_deployment_engine("test-cluster", "default")
    let pod_spec = PodSpec {
        name: "sovereign-api",
        namespace: "default",
        image: "sovereign:v1.0",
        replicas: 3,
        cpu_request: "100m",
        cpu_limit: "500m",
        memory_request: "128Mi",
        memory_limit: "512Mi",
        port: 8080,
        health_check_path: "/healthz",
        readiness_path: "/ready",
        env_vars: [],
        labels: [],
        annotations: []
    }
    let deploy_spec = DeploymentSpec {
        name: "sovereign-api",
        namespace: "default",
        pod_spec: pod_spec,
        strategy: "rolling",
        max_surge: 1,
        max_unavailable: 0,
        min_ready_seconds: 5,
        revision_history_limit: 10,
        progress_deadline_s: 30
    }

    engine = create_deployment(engine, deploy_spec)
    // Simulated deployment is instant (< 30s)
    let deploy_time = engine.avg_deploy_time_ms

    return assert_less_than(
        deploy_time, 30000.0, "E1",
        "K8s deployment < 30s",
        "R5", "ms"
    )
}

fn test_E2_failover_time() -> TestResult {
    // R6: Failover < 5s
    let regions = [
        Region {
            region_id: "us-east-1",
            endpoint: "https://us-east.sovereign.io",
            status: "active",
            priority: 1,
            health_score: 0.95,
            latency_ms: 20.0,
            error_rate: 0.001,
            last_health_check: timestamp_now(),
            active_connections: 1000,
            capacity: 5000,
            data_lag_ms: 10.0
        },
        Region {
            region_id: "eu-west-1",
            endpoint: "https://eu-west.sovereign.io",
            status: "standby",
            priority: 2,
            health_score: 0.90,
            latency_ms: 50.0,
            error_rate: 0.002,
            last_health_check: timestamp_now(),
            active_connections: 100,
            capacity: 5000,
            data_lag_ms: 100.0
        }
    ]

    let engine = create_failover_engine(regions)
    engine = trigger_failover(engine, "us-east-1", "test_failover")

    let failover_time = engine.avg_failover_time_ms

    return assert_less_than(
        failover_time, 5000.0, "E2",
        "Multi-region failover < 5s",
        "R6", "ms"
    )
}

fn test_E3_trace_sampling_rate() -> TestResult {
    // R7: Trace sampling > 1%
    let stack = create_observability_stack()

    // Generate 100 traces
    let i = 0
    while i < 100 {
        let trace = start_trace(stack, "test-op-" + to_string(i), "test-service")
        stack = end_trace(stack, trace)
        i = i + 1
    }

    let sample_rate = get_sample_rate(stack)

    return assert_greater_than(
        sample_rate, 0.01, "E3",
        "Trace sampling rate > 1%",
        "R7", "rate"
    )
}

